---
import { Image } from 'astro:assets';
import Default from '../layouts/Default.astro';
import headshot from '../assets/headshot_halftone_green.png';
---
<Default>
  <div class="wrap">

    <header class="profile-header">
      <Image
        src={headshot}
        alt="Morgan Stone"
        width={128}
        height={128}
        class="avatar"
        loading="eager"
        decoding="async"
        format="avif"
      />
      <p class="eyebrow">Morgan Stone<br>Director of Software Engineering</p>
    </header>

    <h1 class="headline">
      I translate business goals into <strong>high-velocity technical execution</strong> across a 32-person global org.
    </h1>
    <p class="subtitle">Architecture &times; P&amp;L. Came up through marketing and design, went deep on systems, scaled teams through three acquisitions.</p>

    <hr class="rule" aria-hidden="true">

    <p class="eyebrow" style="margin-bottom:18px">Selected impact</p>
    <div class="stats">
      <div>
        <p class="stat-value">$14.5M</p>
        <p class="stat-label">revenue protected<br>SOC 2 Type 1 &amp; 2</p>
      </div>
      <div>
        <p class="stat-value">~44&times;</p>
        <p class="stat-label">deploy frequency<br>bi-weekly &rarr; 22.4/wk</p>
      </div>
      <div>
        <p class="stat-value">$309K</p>
        <p class="stat-label">FinOps savings<br>in one year</p>
      </div>
    </div>

    <p class="eyebrow" style="margin-bottom:12px">Where the $309K came from</p>
    <svg
      class="finops-bar"
      viewBox="0 0 1000 30"
      preserveAspectRatio="none"
      role="img"
      aria-label="FinOps savings: AWS cost 170K (55%), QA infrastructure 94K (30%), version control consolidation 45K (15%)"
    >
      <defs>
        <clipPath id="bar-clip">
          <rect width="1000" height="30" rx="5" ry="5" />
        </clipPath>
      </defs>
      <g clip-path="url(#bar-clip)">
        <rect x="0"   width="550" height="30" fill="#a1be63" />
        <rect x="550" width="304" height="30" fill="#c2d790" />
        <rect x="854" width="146" height="30" fill="#7f9a48" />
      </g>
    </svg>
    <ul class="finops-legend">
      <li><span class="legend-swatch" style="background:#a1be63" aria-hidden="true"></span>AWS cost &middot; $170K</li>
      <li><span class="legend-swatch" style="background:#c2d790" aria-hidden="true"></span>QA infra &middot; $94K</li>
      <li><span class="legend-swatch" style="background:#7f9a48" aria-hidden="true"></span>600+ repos &middot; $45K</li>
    </ul>

    <p class="eyebrow" style="margin-bottom:18px">A decade across three acquisitions</p>
    <div class="timeline">
      <div class="timeline-nodes">
        <div class="timeline-node">
          <div class="timeline-dot" style="background:#5f6f38" aria-hidden="true"></div>
          <p class="timeline-label">Medseek<br>origin</p>
        </div>
        <div class="timeline-node">
          <div class="timeline-dot" style="background:#7f9a48" aria-hidden="true"></div>
          <p class="timeline-label">Influence Health<br>'14</p>
        </div>
        <div class="timeline-node">
          <div class="timeline-dot" style="background:#a1be63" aria-hidden="true"></div>
          <p class="timeline-label timeline-label--highlight">Healthgrades<br>'18</p>
        </div>
        <div class="timeline-node">
          <div class="timeline-dot" style="background:#a1be63" aria-hidden="true"></div>
          <p class="timeline-label">Red Ventures<br>'21</p>
        </div>
        <div class="timeline-node">
          <div class="timeline-dot timeline-dot--active" style="background:#b4ce72" aria-hidden="true"></div>
          <p class="timeline-label timeline-label--highlight">RVO Health<br>'23 &middot; now</p>
        </div>
      </div>
    </div>

  </div>
</Default>
